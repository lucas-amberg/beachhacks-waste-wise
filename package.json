{
  "name": "wastewise",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:web": "turbo dev --filter=@wastewise/web",
    "dev:extension": "turbo dev --filter=@wastewise/extension",
    "build:web": "turbo build --filter=@wastewise/web",
    "build:extension": "turbo build --filter=@wastewise/extension"
  },
  "packageManager": "npm@10.8.2",
  "devDependencies": {
    "turbo": "^2"
  }
}
